SERVER_PORT=8080

# Comma-separated list of allowed origins.
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ADD_SOURCE=false

# Auth (optional)
AUTH_ENABLED=false
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=

# Databases
# Names for connections (used to resolve DB_<NAME>_* variables).
# Example: primary,analytics,secondary
DB_CONNECTIONS=primary

DB_PRIMARY_KIND=mongodb
DB_PRIMARY_URI=mongodb://localhost:27017
DB_PRIMARY_DATABASE=appdb
